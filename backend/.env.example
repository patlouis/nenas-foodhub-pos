# Copy to .env and fill in your real Atlas connection string
PORT=5000
MONGO_URI=mongodb+srv://USER:PASSWORD@CLUSTER.mongodb.net/pos?retryWrites=true&w=majority
# Secret used to sign login tokens — generate with: openssl rand -hex 48
JWT_SECRET=replace-with-a-long-random-string
# Comma-separated list of frontend origins allowed to call this API
ALLOWED_ORIGINS=http://localhost:5173
